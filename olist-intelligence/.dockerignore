# Git metadata
.git
.gitignore
.github/

# Virtual environments
venv/
.venv/
env/
ENV/

# Python cache and test artifacts
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

