.env
.env.*
!.env.example

# IDE and OS files
.vscode/
.idea/
.DS_Store

# Runtime artifacts
mlruns/
mlflow.db
store/
catboost_info/

# Notebook cache
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Large generated reports are not needed in Docker image builds
docs/reports/*.pdf
