# Database Connection (SQLite default)
DATABASE_URL=sqlite:///olist.db
DATA_RAW_PATH=data/raw

# API URL (Dashboard connects to this)
# Local/Mac: http://127.0.0.1:8000
# Docker: http://api:8000
API_URL=http://127.0.0.1:8000
API_KEY=replace-with-a-local-development-key

# Kaggle Credentials (Required for auto-download)
KAGGLE_USERNAME=
KAGGLE_KEY=
